---
import "../styles/index.css";
import "yet-another-react-lightbox/styles.css";

type Props = {
  title?: string;
};

const { title = "Rejs Fest 26" } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<link rel="icon" href={`${baseUrl}favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="is-loading">
		<div class="page-loader" id="page-loader" aria-live="polite">
			<div class="page-loader__inner">
				<p class="page-loader__brand">Rejs Fest</p>
				<p class="page-loader__status">
					Loading<span class="page-loader__dots" aria-hidden="true">...</span>
				</p>
			</div>
		</div>
		<slot />
		<script is:inline>
			const hideLoader = () => {
				document.body.classList.remove("is-loading");
			};

			if (document.readyState === "complete") {
				hideLoader();
			} else {
				window.addEventListener("load", hideLoader, { once: true });
			}
		</script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}

	body {
		min-height: 100%;
	}

	.page-loader {
		position: fixed;
		inset: 0;
		z-index: 9999;
		display: flex;
		align-items: center;
		justify-content: center;
		background:
			radial-gradient(circle at top, rgba(249, 233, 38, 0.18), transparent 34%),
			linear-gradient(180deg, #fff9e6 0%, #f2f5fa 100%);
		color: #21314e;
		opacity: 0;
		pointer-events: none;
		transition: opacity 220ms ease, visibility 220ms ease;
		visibility: hidden;
	}

	.is-loading .page-loader {
		opacity: 1;
		pointer-events: auto;
		visibility: visible;
	}

	.page-loader__inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.75rem;
		padding: 2rem;
		text-align: center;
	}

	.page-loader__brand {
		margin: 0;
		font-family: "RejsFest", cursive;
		font-size: clamp(3rem, 10vw, 6rem);
		line-height: 0.9;
		letter-spacing: 0.03em;
		text-transform: uppercase;
	}

	.page-loader__status {
		margin: 0;
		font-size: 0.95rem;
		font-weight: 900;
		letter-spacing: 0.28em;
		text-transform: uppercase;
	}

	.page-loader__dots {
		display: inline-block;
		width: 1.8em;
		animation: loader-dots 1s infinite ease-in-out;
		overflow: hidden;
		vertical-align: bottom;
	}

	@keyframes loader-dots {
		0%,
		100% {
			opacity: 0.35;
		}
		50% {
			opacity: 1;
		}
	}
</style>
